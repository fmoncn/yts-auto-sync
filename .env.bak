# ── 服务端口 ──────────────────────────────────────────────
YTS_HOST=0.0.0.0
YTS_PORT=4003

# ── RSS 源 (yts.mx 国内被 DNS 污染，默认走 yts.am) ─────────
# URL 模板支持 {quality} 占位符（YTS RSS path 格式：/rss/<keyword>/<quality>/<genre>/<rating>/<lang>）
YTS_RSS_URL=https://yts.am/rss/0/{quality}/all/7/en
# 默认抓取的画质，多个用逗号：720p,1080p,2160p
YTS_QUALITIES=1080p
# RSS 轮询间隔（秒）
YTS_POLL_INTERVAL=600
# 拉 RSS 是否走代理（不需要可留空）
YTS_RSS_PROXY=
# 拉 YTS API 走的代理（直连不通时使用；本机 v2raya HTTP 代理）
YTS_API_PROXY=http://127.0.0.1:20171

# ── qBittorrent ────────────────────────────────────────────
QBIT_URL=http://127.0.0.1:8080
QBIT_USER=admin
QBIT_PASS=9LS6wY2zy
# qBit 完成下载后保存的标签 / 分类（自动建好）
QBIT_CATEGORY=yts
# 下载根目录（必须 qBit 容器内可写）
QBIT_SAVE_PATH=/downloads/movies
QBIT_INCOMPLETE_PATH=/downloads/incomplete

# ── Tracker 增强 ──────────────────────────────────────────
TRACKERS_URL=https://raw.githubusercontent.com/ngosang/trackerslist/master/trackers_best.txt
# tracker 列表本地刷新间隔（小时）
TRACKERS_REFRESH_HOURS=6

# ── 字幕 ──────────────────────────────────────────────────
# 字幕语言（subliminal 语言码，逗号分隔；首个返回中文者胜）
SUB_LANGS=zho,chi
# OpenSubtitles.com 免费 API key（强烈推荐，注册 https://www.opensubtitles.com/）
OPENSUBTITLES_API_KEY=
OPENSUBTITLES_USERNAME=
OPENSUBTITLES_PASSWORD=
# 字幕抓取代理（部分源在国内不通）
SUB_PROXY=http://127.0.0.1:20171

# ── 自动化策略 ────────────────────────────────────────────
# 拉到新条目后是否自动入队
AUTO_DOWNLOAD=true
# 仅下载 IMDB 评分 >= 此值的影片（0 关闭）
MIN_IMDB_RATING=6.5
# 允许的最大文件体积 (GB)，超过跳过
MAX_SIZE_GB=12
# 完成后是否自动调用字幕匹配
AUTO_SUBTITLE=true
